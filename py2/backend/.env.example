# 应用配置
APP_NAME=无限层菜单管理系统
APP_VERSION=1.0.0
DEBUG=True

# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/menu_system?charset=utf8mb4

# JWT配置
